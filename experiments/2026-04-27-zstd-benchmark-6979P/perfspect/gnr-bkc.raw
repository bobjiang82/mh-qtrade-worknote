  "base frequency": {
   "Name": "base frequency",
   "ScriptTemplate": "cat /sys/devices/system/cpu/cpu0/cpufreq/base_frequency",
   "Architectures": null,
   "Vendors": null,
   "MicroArchitectures": null,
   "Lkms": null,
   "Depends": null,
   "Superuser": false,
   "Sequential": false,
   "Stdout": "2100000\n",
   "Stderr": "",
   "Exitcode": 0
  },
  "binutils version": {
   "Name": "binutils version",
   "ScriptTemplate": "ld -v",
   "Architectures": null,
   "Vendors": null,
   "MicroArchitectures": null,
   "Lkms": null,
   "Depends": null,
   "Superuser": false,
   "Sequential": false,
   "Stdout": "GNU ld version 2.35.2-42.el9\n",
   "Stderr": "",
   "Exitcode": 0
  },
  "c-states": {
   "Name": "c-states",
   "ScriptTemplate": "# Directory where C-state information is stored\ncstate_dir=\"/sys/devices/system/cpu/cpu0/cpuidle\"\n\n# Check if the directory exists\nif [ -d \"$cstate_dir\" ]; then\n    for state in \"$cstate_dir\"/state*; do\n        name=$(cat \"$state/name\")\n        disable=$(cat \"$state/disable\")\n        if [ \"$disable\" -eq 0 ]; then\n            status=\"Enabled\"\n        else\n            status=\"Disabled\"\n        fi\n        echo \"$name,$status\"\n    done\nelse\n    echo \"C-state directory not found.\"\nfi\n",
   "Architectures": null,
   "Vendors": null,
   "MicroArchitectures": null,
   "Lkms": null,
   "Depends": null,
   "Superuser": false,
   "Sequential": false,
   "Stdout": "POLL,Enabled\nC1,Enabled\nC1E,Enabled\nC6,Disabled\nC6P,Enabled\n",
   "Stderr": "",
   "Exitcode": 0
  },
  "cha count": {
   "Name": "cha count",
   "ScriptTemplate": "rdmsr 0x396\nrdmsr 0x702\nrdmsr 0x2FFE\n",
   "Architectures": null,
   "Vendors": null,
   "MicroArchitectures": null,
   "Lkms": null,
   "Depends": null,
   "Superuser": false,
   "Sequential": false,
   "Stdout": "7e\n0\n0\n",
   "Stderr": "",
   "Exitcode": 0
  },
